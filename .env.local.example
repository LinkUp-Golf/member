# ============================================================
# LinkUp Golf — Environment Variables
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to version control.
# ============================================================

# ------------------------------------------------------------
# Supabase
# Dashboard → Project Settings → API
# ------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # Server-side only. Bypasses RLS.

# ------------------------------------------------------------
# Go High Level (GHL)
# Settings → Integrations → Private Integrations → API Key
# Location ID: Settings → Business Profile → Location ID
# ------------------------------------------------------------
GHL_API_KEY=your-ghl-private-integration-api-key
GHL_LOCATION_ID=your-ghl-location-id

# Aviara golf calendar ID used for tee time slot queries and booking creation.
# GHL → Calendars → select the Aviara calendar → copy ID from URL or settings.
GHL_AVIARA_CALENDAR_ID=your-aviara-calendar-id

# Webhook secret — must match the value set in GHL webhook config.
GHL_WEBHOOK_SECRET=your-webhook-secret

# ------------------------------------------------------------
# GHL Workflow IDs
# GHL → Automation → Workflows → open each workflow → copy ID from URL.
# These trigger transactional emails/SMS via GHL automation.
# ------------------------------------------------------------
GHL_WORKFLOW_MAGIC_LINK=your-magic-link-workflow-id        # Sends the magic login link email
GHL_WORKFLOW_WELCOME=your-welcome-workflow-id              # Fires when a new member joins
GHL_WORKFLOW_REFERRAL=your-referral-invite-workflow-id     # Sends referral invitation to prospect
GHL_WORKFLOW_BOOKING_CONFIRM=your-booking-confirm-workflow-id  # Booking confirmation to member
GHL_WORKFLOW_FOCUS_2W=your-focus-linkup-2w-workflow-id    # Focus LinkUp reminder 2 weeks out
GHL_WORKFLOW_FOCUS_1W=your-focus-linkup-1w-workflow-id    # Focus LinkUp reminder 1 week out

# ------------------------------------------------------------
# App
# ------------------------------------------------------------
NEXT_PUBLIC_APP_URL=https://app.linkup.golf   # No trailing slash. Used for magic link redirect URLs.

# ------------------------------------------------------------
# Push Notifications (VAPID)
# Generate a key pair ONCE and reuse across deployments.
# Changing keys invalidates all existing push subscriptions.
# Generate: npm run generate-vapid
# ------------------------------------------------------------
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key    # Safe to expose to browser
VAPID_PRIVATE_KEY=your-vapid-private-key              # Server-side only. Never expose.
VAPID_CONTACT_EMAIL=hello@linkup.golf                 # Contact email sent in VAPID header

# ------------------------------------------------------------
# Cron Jobs
# Must match the Authorization header sent by Vercel Cron.
# Use a cryptographically random string of 32+ characters.
# Generate: openssl rand -hex 32
# ------------------------------------------------------------
CRON_SECRET=your-random-cron-secret-min-32-chars

# ------------------------------------------------------------
# Development
# Set to false to disable MSW mock server and hit real APIs.
# Omit or set to true to enable mocking in development.
# ------------------------------------------------------------
NEXT_PUBLIC_MOCK=false
