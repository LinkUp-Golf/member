{
  "name": "linkup-golf",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "generate-vapid": "node -e \"const wp=require('web-push'); const k=wp.generateVAPIDKeys(); console.log('Public:', k.publicKey, '\\nPrivate:', k.privateKey);\"",
    "db:push": "supabase db push",
    "db:reset": "supabase db reset",
    "db:migration": "supabase migration new",
    "db:status": "supabase migration list",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "analyze": "ANALYZE=true next build"
  },
  "dependencies": {
    "@gohighlevel/api-client": "^3.0.0",
    "@supabase/ssr": "^0.3.0",
    "@supabase/supabase-js": "^2.43.0",
    "@vercel/edge-config": "^1.4.3",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "flags": "^4.2.0",
    "next": "14.2.3",
    "next-pwa": "^5.6.0",
    "react": "^18",
    "react-dom": "^18",
    "react-hook-form": "^7.76.1",
    "sharp": "^0.34.5",
    "tailwind-merge": "^3.6.0",
    "web-push": "^3.6.7",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^14.2.35",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/web-push": "^3.6.3",
    "@vitest/coverage-v8": "^4.1.6",
    "autoprefixer": "^10.0.1",
    "eslint": "^8",
    "eslint-config-next": "^14.2.35",
    "msw": "^2.14.6",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5",
    "vitest": "^4.1.6"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
